TELEGRAM_TOKEN=
ADMIN_USER_IDS=123456789
ALLOWED_CHAT_IDS=
# Usa preferibilmente gli ID canonici Telegram, es. -1002097316223.
# Il runtime accetta anche lo shorthand del supergruppo senza prefisso -100.
EXCLUDE_USER_IDS=

AUTOPOST_MIN_MESSAGES=20
AUTOPOST_MAX_MESSAGES=30

REACTION_PROBABILITY=0.06
REACTION_EMOJI=😂,💀,🔥,😭,👀,🤣,😈,💯,🤡,😤,🫡,🥹,💅,🤌

GIF_CONTEXT_MINUTES=15
