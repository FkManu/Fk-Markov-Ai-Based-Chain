TELEGRAM_TOKEN=
GEMINI_API_KEY=
ADMIN_USER_IDS=123456789
ALLOWED_CHAT_IDS=
# Usa preferibilmente gli ID canonici Telegram, es. -1002097316223.
# Il runtime accetta anche lo shorthand del supergruppo senza prefisso -100.
AUTOPOST_MIN_MESSAGES=20
AUTOPOST_MAX_MESSAGES=30
REACTION_PROBABILITY=0.06
REACTION_EMOJI=😂,💀,🔥,😭,👀,🤣,😈,💯,🤡,😤,🫡,🥹,💅,🤌
GIF_CONTEXT_MINUTES=15
GIF_TRIGGER_COUNT=3
GIF_RESEND_PROBABILITY=0.4
GIF_MENTION_PROBABILITY=0.15
GIF_CORPUS_MAX=200
ANNOUNCEMENT_TIMEZONE=Europe/Rome
DATABASE_PATH=runtime/cumbot.sqlite3
EXPORT_PATH=data/export.json
MARKOV_TEXT_MODE=normalized
MARKOV_CANDIDATE_COUNT=8
MARKOV_DRAFT_MAX_CHARS=180
MARKOV_MIN_CANDIDATE_SCORE=2.5
GEMINI_REFINER_MODEL=gemini-2.5-flash-lite
GEMINI_ASK_MODEL=gemini-2.5-flash-lite
