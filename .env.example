GIF_MENTION_PROBABILITY=0.15
GIF_CORPUS_MAX=200
STICKER_RESEND_PROBABILITY=0.08
STICKER_CORPUS_MAX=100

ANNOUNCEMENT_TIMEZONE=Europe/Rome

DATABASE_PATH=runtime/cumbot.sqlite3
EXPORT_PATH=data/export.json
LOG_LEVEL=INFO

MARKOV_TEXT_MODE=normalized
MARKOV_CANDIDATE_COUNT=18
MARKOV_DRAFT_MAX_CHARS=120
